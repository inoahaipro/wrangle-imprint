{
  "_comment": "Add the 'token-firewall' block to your models.providers section in ~/.openclaw/openclaw.json",
  "_comment2": "Copy mcporter.json to ~/.openclaw/workspace/config/mcporter.json for MCP tool access",

  "models_providers_add": {
    "token-firewall": {
      "baseUrl": "http://127.0.0.1:8000/v1",
      "apiKey": "none",
      "api": "openai-completions",
      "models": [
        {
          "id": "firewall",
          "name": "Token Firewall",
          "reasoning": false,
          "input": ["text"],
          "cost": {
            "input": 0,
            "output": 0,
            "cacheRead": 0,
            "cacheWrite": 0
          },
          "contextWindow": 128000,
          "maxTokens": 8192
        }
      ]
    }
  },

  "agents_defaults_models_add": {
    "token-firewall/firewall": {
      "alias": "firewall"
    }
  },

  "_mcp_instructions": [
    "1. Copy skill/mcporter.json to ~/.openclaw/workspace/config/mcporter.json",
    "2. Copy skill/ folder to ~/.openclaw/workspace/skills/token-firewall/",
    "3. Restart OpenClaw",
    "4. Ask your agent: 'what tools do you have?' to verify firewall tools appear"
  ]
}
