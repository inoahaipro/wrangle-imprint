# wrangle-imprint environment configuration
# Copy this file to .env and fill in your values.
# Load with: source .env  (or add to ~/.bashrc)

# ── Required ──────────────────────────────────────────────────────────────────

# OpenClaw session used by IMPRINT for planning in v2.
# OPENCLAW_SESSION=main

# Optional: only needed for direct wrangle text/browser tracks.
# CEREBRAS_KEY=csk-your-key-here

# ── ADB ───────────────────────────────────────────────────────────────────────

# ADB port for localhost connection.
# Default: 34371 (OpenClaw Termux tunnel)
# Standard ADB-over-TCP default is 5555.
# ADB_PORT=34371

# ── IMPRINT ───────────────────────────────────────────────────────────────────

# Path to wrangle.py. Defaults to same directory as imprint.py.
# WRANGLE_PATH=/home/user/wrangle-imprint/wrangle.py

# Path to the SQLite memory database.
# IMPRINT_DB=~/.imprint/memory.db

# Cosine similarity threshold for cache hits (0.0–1.0).
# Lower = fuzzier matching, more cache hits. Higher = stricter.
# IMPRINT_THRESHOLD=0.72

# Number of successful executions required before a plan is marked trusted.
# IMPRINT_CONFIRM=2

# Maximum steps allowed per task before aborting.
# IMPRINT_MAX_STEPS=20

# Task timeout in seconds.
# IMPRINT_TIMEOUT=120

# Retries per failed step before triggering mid-task replan.
# IMPRINT_RETRIES=2

# Set to 1 to enable verbose debug logging.
# IMPRINT_DEBUG=0

# ── wrangle ───────────────────────────────────────────────────────────────────

# Screen resolution — change if you are not on a Samsung S22+ (1080x2340).
# DEVICE_WIDTH=1080
# DEVICE_HEIGHT=2340

# Maximum ranked UI elements sent to the LLM per step.
# WRANGLE_MAX_UI_ELEMENTS=24

# ADB reconnect attempts before giving up.
# WRANGLE_ADB_RETRIES=3

# ── Vision fallback (optional) ────────────────────────────────────────────────

# Ollama endpoint for vision fallback (Moondream). Text track works without this.
# OLLAMA_URL=http://localhost:11434

# Vision model to use via Ollama.
# VISION_MODEL=moondream
